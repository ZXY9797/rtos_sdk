/dts-v1/;

#include <arm/gd/gd32f50x.dtsi>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/gd32-pinctrl.h>

/ {
    compatible = "gd,gd32f503";
    model = "DM-4340 Motor Controller";

    chosen {
        zephyr,console = &usart0;
        zephyr,shell-uart = &usart0;
        zephyr,flash = &flash0;
        zephyr,flash-partition = &slot0_partition;
    };

    pinctrl: pinctrl {
        compatible = "gd,gd32-pinctrl";

        usart0_tx_pa9: usart0_tx_pa9 {
            pinmux = <GD32_PINMUX_AF(GD32_PORT_A, 9, 7,
                                      GD32_PULL_NONE,
                                      GD32_DRIVE_PUSH_PULL, 3)>;
        };

        usart0_rx_pa10: usart0_rx_pa10 {
            pinmux = <GD32_PINMUX_AF(GD32_PORT_A, 10, 7,
                                      GD32_PULL_UP,
                                      GD32_DRIVE_PUSH_PULL, 3)>;
        };

        green_led_pa5: green_led_pa5 {
            pinmux = <GD32_PINMUX_OUTPUT_LOW(GD32_PORT_A, 5,
                                             GD32_PULL_NONE,
                                             GD32_DRIVE_PUSH_PULL, 2)>;
        };

        user_key_pa0: user_key_pa0 {
            pinmux = <GD32_PINMUX_INPUT(GD32_PORT_A, 0,
                                        GD32_PULL_UP, 0)>;
        };
    };

    flash0: flash@8000000 {
        compatible = "soc-nv-flash";
        reg = <0x08000000 0x60000>;  /* 384KB */
        erase-block-size = <2048>;    /* 2KB sector */
        write-block-size = <4>;

        partitions {
            compatible = "fixed-partitions";
            #address-cells = <1>;
            #size-cells = <1>;

            slot0_partition: partition@8000 {
                label = "slot0";
                reg = <0x8000 0x28000>;  /* 160KB */
            };
            upgrade_partition: partition@30000 {
                label = "upgrade";
                reg = <0x30000 0x28000>;  /* 160KB */
            };
            storage_partition: partition@58000 {
                label = "storage";
                reg = <0x58000 0x8000>;   /* 32KB */
            };
        };
    };

    aliases {
        led0 = &green_led;
        key0 = &user_key;
        uart0 = &usart0;
        spi0 = &spi0;
        pwm0 = &timer0;
        tim5 = &timer5;
        tim6 = &timer6;
        adc0 = &adc0;
        motor0 = &motor0;
        imu0 = &imu0;
    };

    leds {
        compatible = "gpio-leds";
        green_led: green_led {
            gpios = <&gpioa 5 0>;
            pinctrl-0 = <&green_led_pa5>;
            pinctrl-names = "default";
            label = "Green LED";
        };
    };

    keys {
        compatible = "gpio-keys";
        user_key: user_key {
            gpios = <&gpioa 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
            pinctrl-0 = <&user_key_pa0>;
            pinctrl-names = "default";
            label = "User Key";
        };
    };

    soc {
        usart0: usart@40013800 {
            compatible = "gd,gd32-usart";
            reg = <0x40013800 0x400>;
            interrupts = <37 0>;
            status = "okay";
            current-speed = <115200>;
            pinctrl-0 = <&usart0_tx_pa9 &usart0_rx_pa10>;
            pinctrl-names = "default";
            label = "USART0";
        };

        spi0: spi@40013000 {
            compatible = "gd,gd32-spi";
            reg = <0x40013000 0x400>;
            interrupts = <35 0>;
            status = "okay";
            spi-max-frequency = <10000000>;
            label = "SPI0";
            #address-cells = <1>;
            #size-cells = <0>;

            imu0: icm40609d@0 {
                compatible = "invensense,icm40609d";
                reg = <0>;
                spi-max-frequency = <10000000>;
                accel-fs = <0>;
                gyro-fs = <0>;
                sample-rate = <16000>;
                int-gpios = <&gpiob 6 0>;
                label = "IMU0";
            };
        };

        dma0: dma@40020000 {
            compatible = "gd,gd32-dma";
            reg = <0x40020000 0x400>;
            interrupts = <11 0>, <12 0>, <13 0>, <14 0>, <15 0>, <16 0>, <17 0>;
            label = "DMA0";
            dma-channels = <7>;
            mux-channels = <7>;
            #dma-cells = <2>;
        };

        dma1: dma@40020400 {
            compatible = "gd,gd32-dma";
            reg = <0x40020400 0x400>;
            interrupts = <56 0>, <57 0>, <58 0>, <59 0>, <68 0>, <69 0>, <70 0>;
            label = "DMA1";
            dma-channels = <7>;
            mux-channels = <5>;
            #dma-cells = <2>;
        };

        gpioa: gpio@40010800 {
            compatible = "gd,gd32-gpio";
            reg = <0x40010800 0x400>;
            interrupts = <0 0>;
            label = "GPIOA";
            gpio-controller;
            #gpio-cells = <2>;
            ngpios = <16>;
        };

        gpiob: gpio@40010C00 {
            compatible = "gd,gd32-gpio";
            reg = <0x40010C00 0x400>;
            interrupts = <1 0>;
            label = "GPIOB";
            gpio-controller;
            #gpio-cells = <2>;
            ngpios = <16>;
        };

        timer0: pwm@40012C00 {
            compatible = "gd,gd32-timer";
            reg = <0x40012C00 0x400>;
            interrupts = <25 0>;
            status = "okay";
            label = "TIMER0";
            channel = <0>;
            #pwm-cells = <3>;
        };

        timer5: timer@40001000 {
            compatible = "gd,gd32-timer";
            reg = <0x40001000 0x400>;
            interrupts = <54 0>;
            status = "okay";
            label = "TIMER5";
            channel = <0>;
            prescaler = <119>;   /* 120MHz / 120 = 1MHz */
            period = <249>;      /* 1MHz / 250 = 4kHz */
            #pwm-cells = <3>;
        };

        timer6: timer@40001400 {
            compatible = "gd,gd32-timer";
            reg = <0x40001400 0x400>;
            interrupts = <55 0>;
            status = "okay";
            label = "TIMER6";
            channel = <0>;
            prescaler = <119>;   /* 120MHz / 120 = 1MHz */
            period = <62>;       /* 1MHz / 63 ≈ 15.87kHz ≈ 16kHz */
            #pwm-cells = <3>;
        };

        adc0: adc@40022800 {
            compatible = "gd,gd32-adc";
            reg = <0x40022800 0x400>;
            interrupts = <18 0>;
            status = "okay";
            label = "ADC0";
            #io-channel-cells = <1>;
        };

        motor0: motor {
            compatible = "foc,motor";
            status = "okay";
            pwm-dev = <&timer0>;
            adc-dev = <&adc0>;
            pwm-ch-u = <0>;
            pwm-ch-v = <1>;
            pwm-ch-w = <2>;
            rs-milliohm = <50>;
            ld-microhenry = <100>;
            lq-microhenry = <100>;
            flux-milliweber = <0>;
            pole-pairs = <14>;
            max-current-ma = <20000>;
            max-voltage-mv = <48000>;
            pwm-frequency = <20000>;
            current-bandwidth = <1000>;
            sensor-mode = <0>;
            control-mode = <1>;
        };
    };
};
