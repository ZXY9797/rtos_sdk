/dts-v1/;

#include <arm/gd/gd32f50x.dtsi>

/ {
    compatible = "gd,gd32f503";
    model = "GD32F503 Demo Board";

    chosen {
        zephyr,console = &usart0;
        zephyr,shell-uart = &usart0;
    };

    aliases {
        led0 = &green_led;
    };

    leds {
        compatible = "gpio-leds";
        green_led: green_led {
            gpios = <&gpioa 5 0>;
            label = "Green LED";
        };
    };

    soc {
        usart0: usart@40013800 {
            compatible = "gd,gd32-usart";
            reg = <0x40013800 0x400>;
            interrupts = <37 0>;
            status = "okay";
            current-speed = <115200>;
            label = "USART0";
        };

        gpioa: gpio@40010800 {
            compatible = "gd,gd32-gpio";
            reg = <0x40010800 0x400>;
            interrupts = <0 0>;
            label = "GPIOA";
            gpio-controller;
            #gpio-cells = <2>;
            ngpios = <16>;
        };
    };
};
