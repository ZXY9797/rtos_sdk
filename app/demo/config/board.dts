/dts-v1/;
#include <st/h7/stm32h743Xi.dtsi>
#include <st/h7/pinctrl/stm32h743vitx-pinctrl.dtsi>

/ {
    compatible = "st,stm32h743xx";

    aliases {
        led0 = &green_led;
        sw0 = &key_pc13;
        console = &usart1;
    };

    chosen {
        sram = &sram0;
        flash = &flash0;
        dtcm = &dtcm;
        itcm = &itcm;
    };

    leds: leds {
        compatible = "gpio-leds";

        green_led: led_0 {
            gpios = <&gpioe 3 GPIO_ACTIVE_HIGH>;
            label = "User LD1";
        };

        key_pc13: led_1 {
            gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
            label = "User Key";
        };
    };
};

&clk_hse {
    clock-frequency = <DT_FREQ_M(25)>;
    status = "okay";
};

&pll {
    div-m = <5>;
    mul-n = <192>;
    div-p = <2>;
    div-q = <2>;
    div-r = <2>;
    clocks = <&clk_hse>;
    status = "okay";
};

&rcc {
    clocks = <&pll>;
    clock-frequency = <DT_FREQ_M(480)>;
    d1cpre = <1>;
    hpre = <2>;
    d1ppre = <2>;
    d2ppre1 = <2>;
    d2ppre2 = <2>;
    d3ppre = <2>;
};

&usart1 {
    pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
    pinctrl-names = "default";
    current-speed = <115200>;
    status = "okay";
};
