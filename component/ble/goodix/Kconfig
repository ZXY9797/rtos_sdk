menuconfig BLE_GR5525
    bool "Goodix GR5525 BLE stack"
    default n
    depends on SOC_SERIES_GR5525X
    help
      Enable Goodix GR5525 BLE protocol stack.

if BLE_GR5525

config BLE_HID
    bool "BLE HID Service (HIDS)"
    default y
    help
      Enable HIDS for BLE HID devices (keyboard/mouse).

config BLE_UART_SERVICE
    bool "BLE UART Service (GUS)"
    default y
    help
      Enable GUS for BLE UART transparent data.

config BLE_HEART_RATE
    bool "BLE Heart Rate Service (HRS)"
    default n
    help
      Enable HRS for BLE heart rate monitoring.

config BLE_BATTERY_SERVICE
    bool "BLE Battery Service (BAS)"
    default y
    help
      Enable BAS for battery level reporting.

config BLE_DEVICE_INFO
    bool "BLE Device Information Service (DIS)"
    default y
    help
      Enable DIS for device information.

config BLE_OTA_SERVICE
    bool "BLE OTA Service (OTAS)"
    default n
    help
      Enable OTAS for over-the-air firmware updates.

config BLE_TASK_STACK_SIZE
    int "BLE task stack size"
    default 2048
    help
      Stack size for the BLE processing task.

config BLE_HEAP_SIZE
    int "BLE heap size (bytes)"
    default 32768
    help
      Heap memory reserved for BLE stack operations.

# ── BLE 协议栈编译时参数 ──

config BLE_MAX_CONNECTIONS
    int "Max BLE connections"
    default 1
    range 1 10
    help
      Maximum number of simultaneous BLE connections (CFG_MAX_CONNECTIONS).

config BLE_MAX_ADVS
    int "Max BLE advertisers"
    default 1
    range 1 5
    help
      Maximum number of BLE advertising sets (CFG_MAX_ADVS).

config BLE_MAX_SCAN
    int "Max BLE scan instances"
    default 0
    range 0 1
    help
      Maximum number of BLE scan instances. 0 = scanning disabled.

config BLE_CONNLESS_AOA_AOD
    bool "Connectionless AoA/AoD support"
    default n
    help
      Enable connectionless Angle of Arrival/Departure support.

config BLE_MAX_BOND_DEVS
    int "Max bonded devices"
    default 1
    range 1 16
    help
      Maximum number of bonded BLE devices (CFG_MAX_BOND_DEVS).

config BLE_MAX_PRFS
    int "Max BLE profiles"
    default 8
    range 1 64
    help
      Maximum number of BLE profiles (CFG_MAX_PRFS).

config BLE_CONTROLLER_ONLY
    bool "BLE controller only (no host)"
    default n
    help
      Build BLE controller only, without the host stack.

endif # BLE_GR5525
