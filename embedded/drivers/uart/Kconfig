menuconfig UART
	bool "UART drivers"
	help
	  Include UART drivers in system config

rsource "Kconfig.stm32"
rsource "Kconfig.gd32"
rsource "Kconfig.gr5525"

if UART

config UART_INIT_PRIORITY
	int "UART init priority"
	default KERNEL_INIT_PRIORITY_DEFAULT
	help
	  UART driver device initialization priority.

endif # UART
