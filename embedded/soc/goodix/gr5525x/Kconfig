# Goodix GR5525x series SoC configuration

config SOC_GR5525X
    bool
    select ARM
    select CPU_CORTEX_M4
    select CPU_HAS_FPU

config SOC
    string
    default "gr5525x"

config SOC_NAME
    string
    default "GR5525X"

# ── GR5525 Boot / Security ──

config GR5525_BOOT_CHECK_IMAGE
    bool "Bootloader image check"
    default y
    help
      Enable bootloader image integrity check before booting.

config GR5525_BOOT_LONG_TIME
    bool "Boot delay for debugger"
    default n
    help
      Add boot delay to allow debugger attachment.

config GR5525_SECURITY_CFG
    int "Security configuration"
    default 0
    help
      Security boot mode: 0=RSA-PKCS1-v2.1, non-zero=ECDSA.
